# ── Central backend configuration ────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env.

# HTTP / TLS
PORT=4001
TLS_KEY_PATH=/usr/local/share/ca-certificates/key.pem
TLS_CERT_PATH=/usr/local/share/ca-certificates/cert.pem

# Auth
# Required. Used to sign admin session cookies. Generate: `openssl rand -hex 32`
CENTRAL_SESSION_SECRET=bda7d80d01ea886486d45ad301011e83a28719377b4e1fea2458796f77451972

# Cookie name for the admin session
CENTRAL_COOKIE_NAME=central_session

# CORS — comma separated list of allowed origins (scheme://ip:port).
# Required when the UI runs on a different origin than the API.
ALLOWED_ORIGINS=https://160.250.65.230:4001

# IP guard for admin endpoints (CIDR list, comma separated).
# Loopback is always allowed.
ADMIN_IP_CIDR=

# Polling
POLL_INTERVAL_MS=30000

# Optional integrations
GEO_LOOKUP=0

# ClickHouse
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
