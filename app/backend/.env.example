# ── Local backend configuration ──────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env.

# HTTP / TLS — three HTTPS listeners (same PORT, different bind IPs + certs).
PORT=3000
TLS_KEY_PATH=/usr/local/share/ca-certificates/key.pem
TLS_CERT_PATH=/usr/local/share/ca-certificates/cert.pem
TLS_INTERNAL_BIND=192.168.178.129
TLS_INTERNAL_KEY_PATH=/usr/local/share/ca-certificates/key.pem
TLS_INTERNAL_CERT_PATH=/usr/local/share/ca-certificates/cert.pem
TLS_PUBLIC_BIND=172.16.0.2
# Use a real public cert in production; below matches internal for dev-only.
TLS_PUBLIC_KEY_PATH=/usr/local/share/ca-certificates/key.pem
TLS_PUBLIC_CERT_PATH=/usr/local/share/ca-certificates/cert.pem
TLS_LOOPBACK_BIND=127.0.0.1

# Auth
# Required. Used to sign admin browser session cookie. `openssl rand -hex 32`
SESSION_SECRET=66b04ab541e424bc2ff6292f7a3f760071e7b88327b791748d482415910dfaba
# Required. Used to sign device JWTs. `openssl rand -hex 32`
JWT_SECRET=3e6dba744a3ff56d9487eb83a40deb222a1c12acf967edc14bcc85f0f0ded200

# CORS — comma separated list of allowed origins (scheme://ip:port).
ALLOWED_ORIGINS=https://192.168.178.129:3000,https://172.16.0.2:3000,https://127.0.0.1:3000

# IP guard for admin endpoints (CIDR list, comma separated).
ADMIN_IP_CIDR=192.168.178.0/24

# Database
WG_DB_HOST=localhost
WG_DB_USER=root
WG_DB_PASSWORD=root
WG_DB_NAME=wg_monitor

# Central
# Base URL of the central server (used for register, sync, metrics push).
CENTRAL_URL=https://160.250.65.230:4001

# Single API key for this node, issued by central when admin clicks "Add node".
# Used by: /api/register, /api/metrics/push, /api/logs/push (Vector),
# POST /api/notifications/ingest (Vector), and central → local callbacks.
NODE_API_KEY=

# How often to push metrics to central (ms).
METRICS_PUSH_INTERVAL_MS=30000

# Public/poll base URL announced to central (HTTPS endpoint reachable by central).
CENTRAL_POLL_BASE_URL=https://127.0.0.1:4000
CENTRAL_PUBLIC_IP=

# Optional friendly name reported to central.
CENTRAL_NODE_NAME=vpn-node-2
